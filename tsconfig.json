{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleResolution": "bundler",
    "allowJs": true,

    "strict": true,
    "skipLibCheck": true,

    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "rootDir": "./src",
    "outDir": "./dist",

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    
    "paths": {
      "@base": ["./src/core"],
      "@types": ["./src/core/types"],
      "@modules": ["./src/core/modules"],
      "@utils": ["./src/core/utils"],
    }
  },

  "include": ["src"]
}